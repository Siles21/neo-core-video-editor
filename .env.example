# Existing
GOOGLE_API_KEY=

# Canva Connect API (https://www.canva.com/developers/)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=https://your-domain.vercel.app/api/oauth/canva/callback

# Dropbox API (https://www.dropbox.com/developers/apps)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=https://your-domain.vercel.app/api/oauth/dropbox/callback

# Upstash Redis (Vercel Marketplace → Storage → KV/Upstash)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Schützt die Setup-Seite und alle /api/config-Endpoints
ADMIN_PASSWORD=

# Optional: schützt /api/worker/sync vor fremden Aufrufen
WORKER_SECRET=
